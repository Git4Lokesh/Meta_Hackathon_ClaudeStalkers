*.egg
dist/
build/
.env

# Training outputs (only commit final metrics.json + .png plots manually)
outputs/sft_dataset*.json
outputs/war_room_grpo/final_model/
outputs/war_room_grpo/checkpoint-*
outputs/war_room_sft/
